{
  "name": "@atelier-kit/atelier-kit",
  "version": "0.1.3",
  "description": "Filesystem-native Planning Protocol for coding agents (.atelier/)",
  "type": "module",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/atelier-kit/atelier-kit.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "ai",
    "agents",
    "cursor",
    "claude",
    "planner",
    "workflow"
  ],
  "bin": {
    "atelier": "./dist/cli.js",
    "atelier-kit": "./dist/cli.js"
  },
  "files": [
    "dist",
    "kit",
    "LICENSE",
    "CREDITS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm test"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "commander": "^12.1.0",
    "gray-matter": "^4.0.3",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
