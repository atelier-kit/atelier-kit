{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atelier-kit.dev/schemas/active.schema.json",
  "title": "Atelier activation",
  "type": "object",
  "additionalProperties": false,
  "required": ["active", "mode", "active_epic", "active_phase", "active_skill", "updated_at"],
  "properties": {
    "active": { "type": "boolean" },
    "mode": {
      "type": "string",
      "enum": ["native", "atelier"]
    },
    "active_epic": { "type": ["string", "null"], "minLength": 1 },
    "active_phase": { "type": ["string", "null"] },
    "active_skill": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"], "format": "date-time" }
  }
}
