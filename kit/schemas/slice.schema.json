{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atelier-kit.dev/schemas/slice.schema.json",
  "title": "Execution slice",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "id",
    "title",
    "status",
    "goal",
    "depends_on",
    "allowed_files",
    "acceptance_criteria",
    "validation"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": {
      "type": "string",
      "enum": ["draft", "ready", "executing", "done", "blocked", "needs-review"]
    },
    "goal": { "type": "string", "minLength": 1 },
    "depends_on": {
      "type": "array",
      "items": { "type": "string" }
    },
    "allowed_files": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
